{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.cache/tsc/tsconfig.client.tsbuildinfo",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./client/*"]
    }
  },
  "include": ["client/**/*", "vite-env.d.ts"],
  "exclude": ["node_modules", "dist", "server"]
}
